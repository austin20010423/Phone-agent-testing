# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Optional for the first caller smoke test.
# Needed later if Twilio should call back into this local Python app.
PUBLIC_BASE_URL=

# Safety guard: the app refuses to call any number except this value.
PG_TEST_NUMBER=+18054398008

# OpenRouter, used by the webhook conversation loop.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
